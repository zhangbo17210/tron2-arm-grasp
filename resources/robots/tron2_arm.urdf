<?xml version="1.0"?>
<robot name="tron2_arm">

  <!-- Base link (fixed to table) -->
  <link name="base">
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.05"/>
      </geometry>
      <material name="base_grey">
        <color rgba="0.4 0.4 0.4 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.05"/>
      </geometry>
    </collision>
  </link>

  <!-- Joint 1: base rotation (yaw) -->
  <joint name="joint1" type="revolute">
    <parent link="base"/>
    <child link="link1"/>
    <origin xyz="0 0 0.025" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="50.0" velocity="2.0"/>
    <dynamics damping="1.5" friction="0.1"/>
  </joint>

  <!-- Link 1: shoulder -->
  <link name="link1">
    <inertial>
      <mass value="0.8"/>
      <inertia ixx="0.005" ixy="0.0" ixz="0.0" iyy="0.005" iyz="0.0" izz="0.005"/>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.04 0.1"/>
      </geometry>
      <material name="link_orange">
        <color rgba="0.9 0.4 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.04 0.1"/>
      </geometry>
    </collision>
  </link>

  <!-- Joint 2: shoulder pitch -->
  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="100.0" velocity="2.0"/>
    <dynamics damping="2.0" friction="0.1"/>
  </joint>

  <!-- Link 2: upper arm -->
  <link name="link2">
    <inertial>
      <mass value="1.2"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.03 0.2"/>
      </geometry>
      <material name="link_orange">
        <color rgba="0.9 0.4 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.03 0.2"/>
      </geometry>
    </collision>
  </link>

  <!-- Joint 3: elbow pitch -->
  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0 0 0.2" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="0.5" effort="80.0" velocity="2.0"/>
    <dynamics damping="1.5" friction="0.1"/>
  </joint>

  <!-- Link 3: forearm -->
  <link name="link3">
    <inertial>
      <mass value="0.6"/>
      <inertia ixx="0.005" ixy="0.0" ixz="0.0" iyy="0.005" iyz="0.0" izz="0.005"/>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry>
        <box size="0.025 0.025 0.2"/>
      </geometry>
      <material name="link_dark">
        <color rgba="0.3 0.3 0.35 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry>
        <box size="0.025 0.025 0.2"/>
      </geometry>
    </collision>
  </link>

  <!-- Joint 4: wrist pitch -->
  <joint name="joint4" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="0 0 0.2" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="2.0" effort="40.0" velocity="2.0"/>
    <dynamics damping="0.8" friction="0.05"/>
  </joint>

  <!-- Link 4: wrist roll -->
  <link name="link4">
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.02" length="0.06"/>
      </geometry>
      <material name="link_dark">
        <color rgba="0.3 0.3 0.35 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.02" length="0.06"/>
      </geometry>
    </collision>
  </link>

  <!-- Joint 5: wrist roll -->
  <joint name="joint5" type="revolute">
    <parent link="link4"/>
    <child link="link5"/>
    <origin xyz="0 0 0.06" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="30.0" velocity="3.0"/>
    <dynamics damping="0.5" friction="0.05"/>
  </joint>

  <!-- Link 5: gripper base -->
  <link name="link5">
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.02 0.04"/>
      </geometry>
      <material name="gripper_metal">
        <color rgba="0.6 0.6 0.65 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.02 0.04"/>
      </geometry>
    </collision>
  </link>

  <!-- Joint 6: gripper yaw -->
  <joint name="joint6" type="revolute">
    <parent link="link5"/>
    <child link="gripper_palm"/>
    <origin xyz="0 0 0.04" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.5" upper="0.5" effort="20.0" velocity="1.0"/>
    <dynamics damping="0.3" friction="0.05"/>
  </joint>

  <!-- Gripper palm -->
  <link name="gripper_palm">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0005" ixy="0.0" ixz="0.0" iyy="0.0005" iyz="0.0" izz="0.0005"/>
      <origin xyz="0 0 0.01" rpy="0 0 0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.01" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.04 0.02"/>
      </geometry>
      <material name="gripper_metal">
        <color rgba="0.6 0.6 0.65 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.01" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.04 0.02"/>
      </geometry>
    </collision>
  </link>

  <!-- Gripper left finger -->
  <joint name="gripper_left" type="prismatic">
    <parent link="gripper_palm"/>
    <child link="gripper_left_finger"/>
    <origin xyz="0 0.02 0.02" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0.0" upper="0.04" effort="20.0" velocity="0.5"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <link name="gripper_left_finger">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
      <origin xyz="0 0 0.01" rpy="0 0 0"/>
    </inertial>
    <visual>
      <origin xyz="0.02 0 0.01" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.01 0.02"/>
      </geometry>
      <material name="finger_blue">
        <color rgba="0.2 0.4 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.02 0 0.01" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.01 0.02"/>
      </geometry>
    </collision>
  </link>

  <!-- Gripper right finger -->
  <joint name="gripper_right" type="prismatic">
    <parent link="gripper_palm"/>
    <child link="gripper_right_finger"/>
    <origin xyz="0 -0.02 0.02" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.04" upper="0.0" effort="20.0" velocity="0.5"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <link name="gripper_right_finger">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
      <origin xyz="0 0 0.01" rpy="0 0 0"/>
    </inertial>
    <visual>
      <origin xyz="0.02 0 0.01" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.01 0.02"/>
      </geometry>
      <material name="finger_blue">
        <color rgba="0.2 0.4 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.02 0 0.01" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.01 0.02"/>
      </geometry>
    </collision>
  </link>

  <!-- Gripper tips for contact detection -->
  <link name="gripper_tip_left">
    <visual>
      <origin xyz="0.06 0 0.01" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.005"/>
      </geometry>
      <material name="tip_red">
        <color rgba="1.0 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.06 0 0.01" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.005"/>
      </geometry>
    </collision>
  </link>

  <link name="gripper_tip_right">
    <visual>
      <origin xyz="0.06 0 0.01" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.005"/>
      </geometry>
      <material name="tip_red">
        <color rgba="1.0 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.06 0 0.01" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.005"/>
      </geometry>
    </collision>
  </link>

  <!-- Fixed joints for gripper tips -->
  <joint name="gripper_tip_left_joint" type="fixed">
    <parent link="gripper_left_finger"/>
    <child link="gripper_tip_left"/>
    <origin xyz="0.04 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="gripper_tip_right_joint" type="fixed">
    <parent link="gripper_right_finger"/>
    <child link="gripper_tip_right"/>
    <origin xyz="0.04 0 0" rpy="0 0 0"/>
  </joint>

</robot>
